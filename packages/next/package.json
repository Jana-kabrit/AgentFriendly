{
  "name": "@agentfriendly/next",
  "version": "0.1.0",
  "description": "Next.js adapter for @agentfriendly — Edge Runtime compatible middleware",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentfriendly/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^2.0.0",
    "next": "^15.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "keywords": [
    "next.js",
    "ai",
    "agent",
    "middleware"
  ],
  "license": "MIT"
}
