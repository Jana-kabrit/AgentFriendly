{
  "name": "@agentfriendly/core",
  "version": "0.1.0",
  "description": "Framework-agnostic core for the @agentfriendly SDK — all 8 layers of agent-friendly web infrastructure",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./detection": {
      "types": "./dist/detection/index.d.ts",
      "import": "./dist/detection/index.js"
    },
    "./discovery": {
      "types": "./dist/discovery/index.d.ts",
      "import": "./dist/discovery/index.js"
    },
    "./content": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.js"
    },
    "./analytics": {
      "types": "./dist/analytics/index.d.ts",
      "import": "./dist/analytics/index.js"
    },
    "./access": {
      "types": "./dist/access/index.d.ts",
      "import": "./dist/access/index.js"
    },
    "./privacy": {
      "types": "./dist/privacy/index.d.ts",
      "import": "./dist/privacy/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    },
    "./monetization": {
      "types": "./dist/monetization/index.d.ts",
      "import": "./dist/monetization/index.js"
    },
    "./multitenancy": {
      "types": "./dist/multitenancy/index.d.ts",
      "import": "./dist/multitenancy/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --reporter=verbose",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentfriendly/ua-database": "workspace:*",
    "@noble/ed25519": "^2.1.0",
    "jose": "^5.9.0",
    "micromatch": "^4.0.8"
  },
  "devDependencies": {
    "@mozilla/readability": "^0.5.0",
    "@types/jsdom": "^28.0.0",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.19.15",
    "@types/turndown": "^5.0.4",
    "@vitest/coverage-v8": "^2.0.0",
    "jsdom": "^28.1.0",
    "turndown": "^7.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "keywords": [
    "ai",
    "agent",
    "sdk",
    "middleware",
    "llms",
    "webagents"
  ],
  "license": "MIT"
}
